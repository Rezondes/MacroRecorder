<Window x:Class="MacroRecorder.App.ApplicationSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
        Title="{loc:Loc Main_Settings_Title}"
        Width="360"
        Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Border Margin="20" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="20">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="{loc:Loc Common_Cancel}"
                        Width="96"
                        Margin="0,0,8,0"
                        Padding="10,6"
                        IsCancel="True"
                        Click="OnCancel" />
                <Button Content="{loc:Loc Main_Settings_Save}"
                        Width="96"
                        Padding="10,6"
                        IsDefault="True"
                        Click="OnSave" />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="{loc:Loc Main_Settings_LanguageHeader}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#1A1A1A"
                           Margin="0,0,0,10" />
                <RadioButton x:Name="RbGerman"
                             GroupName="UiLanguage"
                             Content="{loc:Loc Main_Menu_LanguageGerman}"
                             FontSize="13"
                             Margin="0,0,0,8" />
                <RadioButton x:Name="RbEnglish"
                             GroupName="UiLanguage"
                             Content="{loc:Loc Main_Menu_LanguageEnglish}"
                             FontSize="13" />
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
