<UserControl x:Class="MacroRecorder.App.Controls.PlayMacroGlyphButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="Self"
             mc:Ignorable="d"
             d:DesignHeight="40"
             d:DesignWidth="40">
    <Button Style="{DynamicResource UiIconButtonSuccessGlyph}"
            PreviewMouseLeftButtonDown="OnPlayPreviewMouseLeftButtonDown"
            Command="{Binding Command, ElementName=Self}"
            CommandParameter="{Binding CommandParameter, ElementName=Self}"
            IsEnabled="{Binding IsEnabled, ElementName=Self}"
            ToolTip="{loc:Loc Main_Play}"
            AutomationProperties.Name="{loc:Loc Main_Play}">
        <TextBlock FontFamily="Segoe MDL2 Assets"
                   Text="&#xE768;"
                   FontSize="18"
                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
    </Button>
</UserControl>
