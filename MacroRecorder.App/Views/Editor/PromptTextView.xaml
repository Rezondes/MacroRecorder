<UserControl x:Class="MacroRecorder.App.Views.Editor.PromptTextView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             xmlns:wpf="clr-namespace:MacroRecorder.Wpf.Controls;assembly=MacroRecorder.Wpf"
             Background="Transparent"
             Focusable="True">
    <Border Style="{DynamicResource UiDialogSurface}"
            Padding="22">
        <StackPanel MinWidth="360">
            <TextBlock x:Name="TitleBlock"
                       Style="{DynamicResource UiDialogTitle}"
                       FontSize="16"
                       Margin="0,0,0,8" />
            <TextBlock x:Name="MessageBlock"
                       Style="{DynamicResource UiDialogDescription}"
                       FontSize="13"
                       Margin="0,0,0,14"
                       LineHeight="20" />
            <wpf:DigitsOnlyNumericBox x:Name="InputNumeric"
                                      Margin="0,0,0,8"
                                      InputFontSize="14"
                                      MinInnerHeight="40"
                                      SpinUpToolTip="{loc:Loc Editor_PromptWaitSpinUp}"
                                      SpinDownToolTip="{loc:Loc Editor_PromptWaitSpinDown}" />
            <TextBlock x:Name="ErrorBlock"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="{DynamicResource UiBrush.Error}"
                       Margin="0,0,0,12" />
            <StackPanel Style="{DynamicResource UiDialogFooter}"
                        Margin="0,0,0,0">
                <Button Content="{loc:Loc Common_Cancel}"
                        MinWidth="100"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Style="{DynamicResource UiButtonChrome}"
                        Click="OnCancelClick" />
                <Button Content="{loc:Loc Common_Ok}"
                        MinWidth="100"
                        Padding="12,6"
                        IsDefault="True"
                        Style="{DynamicResource UiPrimaryButton}"
                        Click="OnOkClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
