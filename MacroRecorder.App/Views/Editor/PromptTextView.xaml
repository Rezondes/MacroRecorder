<UserControl x:Class="MacroRecorder.App.Views.Editor.PromptTextView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             Background="Transparent"
             Focusable="True">
    <UserControl.Resources>
        <Style x:Key="UiPromptSpinnerRepeatButton" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource UiBrush.SurfaceHover}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource UiBrush.SurfaceSelected}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="UiPromptSpinnerArrowPath" TargetType="Path">
            <Setter Property="Stroke" Value="{DynamicResource UiBrush.TextSecondary}" />
            <Setter Property="StrokeThickness" Value="1.6" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Stretch" Value="None" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RepeatButton}}"
                             Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource UiBrush.TextPrimary}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsPressed, RelativeSource={RelativeSource AncestorType=RepeatButton}}"
                             Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource UiBrush.Primary}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Border Background="{DynamicResource UiBrush.Surface}"
            BorderBrush="{DynamicResource UiBrush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="22">
        <StackPanel MinWidth="360">
            <TextBlock x:Name="TitleBlock"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource UiBrush.TextPrimary}"
                       Margin="0,0,0,8" />
            <TextBlock x:Name="MessageBlock"
                       TextWrapping="Wrap"
                       FontSize="13"
                       Foreground="{DynamicResource UiBrush.TextSecondary}"
                       LineHeight="20"
                       Margin="0,0,0,14" />
            <Border x:Name="InputRowBorder"
                    Margin="0,0,0,8"
                    Background="{DynamicResource UiBrush.SurfaceElevated}"
                    BorderBrush="{DynamicResource UiBrush.Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    SnapsToDevicePixels="True">
                <Grid MinHeight="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="InputBox"
                             Grid.Column="0"
                             FontSize="14"
                             Padding="10,8"
                             MinHeight="40"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource UiBrush.TextPrimary}"
                             CaretBrush="{DynamicResource UiBrush.TextPrimary}"
                             SelectionBrush="{DynamicResource UiBrush.SurfaceSelected}"
                             SelectionTextBrush="{DynamicResource UiBrush.TextPrimary}"
                             VerticalContentAlignment="Center" />
                    <Grid x:Name="NumericSpinner"
                          Grid.Column="1"
                          Width="34"
                          Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <RepeatButton x:Name="SpinnerUp"
                                      Grid.Row="0"
                                      Delay="400"
                                      Interval="80"
                                      Style="{StaticResource UiPromptSpinnerRepeatButton}"
                                      Cursor="Hand"
                                      ToolTip="{loc:Loc Editor_PromptWaitSpinUp}"
                                      Click="OnSpinnerUpClick">
                            <Path Data="M 0 7 L 7 1 L 14 7"
                                  Style="{StaticResource UiPromptSpinnerArrowPath}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </RepeatButton>
                        <Border Grid.Row="1"
                                Height="1"
                                Background="{DynamicResource UiBrush.Border}" />
                        <RepeatButton x:Name="SpinnerDown"
                                      Grid.Row="2"
                                      Delay="400"
                                      Interval="80"
                                      Style="{StaticResource UiPromptSpinnerRepeatButton}"
                                      Cursor="Hand"
                                      ToolTip="{loc:Loc Editor_PromptWaitSpinDown}"
                                      Click="OnSpinnerDownClick">
                            <Path Data="M 0 1 L 7 7 L 14 1"
                                  Style="{StaticResource UiPromptSpinnerArrowPath}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </RepeatButton>
                    </Grid>
                </Grid>
            </Border>
            <TextBlock x:Name="ErrorBlock"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="{DynamicResource UiBrush.Error}"
                       Margin="0,0,0,12" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="{loc:Loc Common_Cancel}"
                        MinWidth="100"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Style="{DynamicResource UiButtonChrome}"
                        Click="OnCancelClick" />
                <Button Content="{loc:Loc Common_Ok}"
                        MinWidth="100"
                        Padding="12,6"
                        IsDefault="True"
                        Style="{DynamicResource UiPrimaryButton}"
                        Click="OnOkClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
