<Window x:Class="MacroRecorder.App.Views.Editor.InsertMouseClickDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
        Title="{loc:Loc DialogInsertMouse_Title}"
        Width="400" Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FAFAFA">
    <Border Margin="20" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="{loc:Loc DialogInsertMouse_Heading}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#1A1A1A"
                       Margin="0,0,0,4" />
            <TextBlock Grid.Row="1"
                       Text="{loc:Loc DialogInsertMouse_Description}"
                       FontSize="12"
                       Foreground="#666666"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16" />
            <ComboBox x:Name="ButtonCombo" Grid.Row="2" Margin="0,0,0,12" FontSize="13" MinHeight="32" />
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{loc:Loc DialogInsertMouse_LabelX}" FontSize="11" Foreground="#555555" Margin="0,0,0,4" />
                        <TextBox x:Name="XBox" FontSize="13" MinHeight="32" Padding="8,4" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{loc:Loc DialogInsertMouse_LabelY}" FontSize="11" Foreground="#555555" Margin="0,0,0,4" />
                        <TextBox x:Name="YBox" FontSize="13" MinHeight="32" Padding="8,4" />
                    </StackPanel>
                </Grid>
                <Button Grid.Row="1"
                        Content="{loc:Loc DialogInsertMouse_UseCursorPosition}"
                        Margin="0,14,0,0"
                        Padding="12,8"
                        HorizontalAlignment="Stretch"
                        Click="OnCaptureClick" />
            </Grid>
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="{loc:Loc Common_Cancel}" Width="100" Margin="0,0,8,0" Padding="10,6" IsCancel="True" />
                <Button Content="{loc:Loc Common_Ok}" Width="100" Padding="10,6" IsDefault="True" Click="OnOk" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
