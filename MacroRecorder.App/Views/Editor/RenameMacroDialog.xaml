<Window x:Class="MacroRecorder.App.Views.Editor.RenameMacroDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
        Title="{loc:Loc DialogRename_Title}"
        Width="420" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FAFAFA">
    <Border Margin="20" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="20">
        <StackPanel>
            <TextBlock Text="{loc:Loc DialogRename_LabelName}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#1A1A1A"
                       Margin="0,0,0,12" />
            <TextBox x:Name="NameBox" FontSize="14" MinHeight="36" Padding="10,6" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="{loc:Loc Common_Cancel}" Width="100" Margin="0,0,8,0" Padding="10,6" IsCancel="True" />
                <Button Content="{loc:Loc Common_Ok}" Width="100" Padding="10,6" IsDefault="True" Click="OnOk" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
