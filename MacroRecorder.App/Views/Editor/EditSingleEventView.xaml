<UserControl x:Class="MacroRecorder.App.Views.Editor.EditSingleEventView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             Background="Transparent"
             Focusable="True">
    <Border Style="{DynamicResource UiDialogSurface}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Style="{DynamicResource UiDialogTitle}"
                       Text="{loc:Loc DialogEdit_HeadingValues}" />
            <TextBlock DockPanel.Dock="Top"
                       Style="{DynamicResource UiDialogDescription}"
                       Text="{loc:Loc DialogEdit_DescriptionValues}" />
            <StackPanel DockPanel.Dock="Bottom"
                        Style="{DynamicResource UiDialogFooter}"
                        Margin="0,16,0,0">
                <Button Content="{loc:Loc Common_Cancel}"
                        MinWidth="100"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Style="{DynamicResource UiButtonChrome}"
                        Click="OnCancelClick" />
                <Button Content="{loc:Loc Common_Ok}"
                        MinWidth="100"
                        Padding="12,6"
                        IsDefault="True"
                        Style="{DynamicResource UiPrimaryButton}"
                        Click="OnOkClick" />
            </StackPanel>
            <ScrollViewer Style="{DynamicResource UiSettingsFormScrollViewer}">
                <StackPanel x:Name="FieldsPanel" />
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
