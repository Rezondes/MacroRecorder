<UserControl x:Class="MacroRecorder.App.Views.Editor.EditSingleEventView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             Background="Transparent"
             Focusable="True">
    <Border Background="{DynamicResource UiBrush.Surface}"
            BorderBrush="{DynamicResource UiBrush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="20">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Text="{loc:Loc DialogEdit_HeadingValues}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource UiBrush.TextPrimary}"
                       Margin="0,0,0,8" />
            <TextBlock DockPanel.Dock="Top"
                       Text="{loc:Loc DialogEdit_DescriptionValues}"
                       FontSize="12"
                       Foreground="{DynamicResource UiBrush.TextSecondary}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12" />
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="{loc:Loc Common_Cancel}"
                        MinWidth="100"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Style="{DynamicResource UiButtonChrome}"
                        Click="OnCancelClick" />
                <Button Content="{loc:Loc Common_Ok}"
                        MinWidth="100"
                        Padding="12,6"
                        IsDefault="True"
                        Style="{DynamicResource UiPrimaryButton}"
                        Click="OnOkClick" />
            </StackPanel>
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="0,0,4,0">
                <StackPanel x:Name="FieldsPanel" />
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
