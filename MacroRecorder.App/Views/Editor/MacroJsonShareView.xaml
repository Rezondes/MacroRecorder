<UserControl x:Class="MacroRecorder.App.Views.Editor.MacroJsonShareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             Background="Transparent"
             Focusable="True">
    <Border Style="{DynamicResource UiDialogSurface}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="200" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Style="{DynamicResource UiDialogTitle}"
                       Margin="0,0,0,12"
                       Text="{loc:Loc Editor_ShareJson_ModalTitle}" />
            <Border Grid.Row="1"
                    Margin="0,0,0,16"
                    Background="{DynamicResource UiBrush.SurfaceElevated}"
                    BorderBrush="{DynamicResource UiBrush.Border}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="0">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="JsonBox"
                             AcceptsReturn="True"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="12"
                             HorizontalScrollBarVisibility="Hidden"
                             IsReadOnly="True"
                             IsReadOnlyCaretVisible="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Hidden" />
                </ScrollViewer>
            </Border>
            <StackPanel Grid.Row="2"
                        Style="{DynamicResource UiDialogFooter}">
                <Button MinWidth="100"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Click="OnCloseClick"
                        Content="{loc:Loc Editor_ShareJson_Close}"
                        Style="{DynamicResource UiButtonChrome}" />
                <Button MinWidth="100"
                        Padding="12,6"
                        Click="OnExportClick"
                        Content="{loc:Loc Editor_ShareJson_Export}"
                        Style="{DynamicResource UiPrimaryButton}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
