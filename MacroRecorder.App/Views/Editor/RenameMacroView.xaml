<UserControl x:Class="MacroRecorder.App.Views.Editor.RenameMacroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             Background="Transparent"
             Focusable="True">
    <Border Background="{DynamicResource UiBrush.Surface}"
            BorderBrush="{DynamicResource UiBrush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="20">
        <StackPanel>
            <TextBlock Text="{loc:Loc DialogRename_LabelName}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource UiBrush.TextPrimary}"
                       Margin="0,0,0,12" />
            <TextBox x:Name="NameBox"
                     FontSize="14"
                     MinHeight="40"
                     Padding="10,8" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="{loc:Loc Common_Cancel}"
                        MinWidth="100"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Style="{DynamicResource UiButtonChrome}"
                        Click="OnCancelClick" />
                <Button Content="{loc:Loc Common_Ok}"
                        MinWidth="100"
                        Padding="12,6"
                        IsDefault="True"
                        Style="{DynamicResource UiPrimaryButton}"
                        Click="OnOkClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
