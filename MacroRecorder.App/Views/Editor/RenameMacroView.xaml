<UserControl x:Class="MacroRecorder.App.Views.Editor.RenameMacroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             Background="Transparent"
             Focusable="True">
    <Border Style="{DynamicResource UiDialogSurface}">
        <StackPanel>
            <TextBlock Style="{DynamicResource UiDialogTitle}"
                       Margin="0,0,0,12"
                       Text="{loc:Loc DialogRename_LabelName}" />
            <TextBox x:Name="NameBox"
                     FontSize="14"
                     MinHeight="40"
                     Padding="10,8" />
            <StackPanel Style="{DynamicResource UiDialogFooter}">
                <Button Content="{loc:Loc Common_Cancel}"
                        MinWidth="100"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Style="{DynamicResource UiButtonChrome}"
                        Click="OnCancelClick" />
                <Button Content="{loc:Loc Common_Ok}"
                        MinWidth="100"
                        Padding="12,6"
                        IsDefault="True"
                        Style="{DynamicResource UiPrimaryButton}"
                        Click="OnOkClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
