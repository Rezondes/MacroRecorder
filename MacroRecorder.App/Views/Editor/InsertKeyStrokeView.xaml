<UserControl x:Class="MacroRecorder.App.Views.Editor.InsertKeyStrokeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             Background="Transparent"
             Focusable="True"
             PreviewKeyDown="OnPreviewKeyDown">
    <Border Style="{DynamicResource UiDialogSurface}">
        <StackPanel>
            <TextBlock Style="{DynamicResource UiDialogTitle}"
                       Margin="0,0,0,4"
                       Text="{loc:Loc DialogInsertKey_Heading}" />
            <TextBlock Style="{DynamicResource UiDialogDescription}"
                       Text="{loc:Loc DialogInsertKey_Description}" />
            <Border Background="{DynamicResource UiBrush.SurfaceElevated}"
                    BorderBrush="{DynamicResource UiBrush.Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,10">
                <TextBlock x:Name="StatusText"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource UiBrush.Primary}"
                           Text="" />
            </Border>
            <StackPanel Style="{DynamicResource UiDialogFooter}"
                        Margin="0,24,0,0">
                <Button Content="{loc:Loc Common_Cancel}"
                        MinWidth="100"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Style="{DynamicResource UiButtonChrome}"
                        Click="OnCancelClick" />
                <Button Content="{loc:Loc Common_Ok}"
                        MinWidth="100"
                        Padding="12,6"
                        IsDefault="True"
                        Style="{DynamicResource UiPrimaryButton}"
                        Click="OnOkClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
