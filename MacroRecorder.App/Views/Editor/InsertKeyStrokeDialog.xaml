<Window x:Class="MacroRecorder.App.Views.Editor.InsertKeyStrokeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
        Title="{loc:Loc DialogInsertKey_Title}"
        Width="440" Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FAFAFA"
        PreviewKeyDown="OnPreviewKeyDown">
    <Border Margin="20" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="20">
        <StackPanel>
            <TextBlock Text="{loc:Loc DialogInsertKey_Heading}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#1A1A1A"
                       Margin="0,0,0,4" />
            <TextBlock FontSize="12"
                       Foreground="#666666"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"
                       Text="{loc:Loc DialogInsertKey_Description}" />
            <Border Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="12,10">
                <TextBlock x:Name="StatusText"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#0F6CBD"
                           Text="" />
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="{loc:Loc Common_Cancel}" Width="100" Margin="0,0,8,0" Padding="10,6" IsCancel="True" />
                <Button Content="{loc:Loc Common_Ok}" Width="100" Padding="10,6" IsDefault="True" Click="OnOk" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
