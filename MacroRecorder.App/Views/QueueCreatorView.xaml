<UserControl x:Class="MacroRecorder.App.Views.QueueCreatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:MacroRecorder.App.ViewModels"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             xmlns:local="clr-namespace:MacroRecorder.App"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:QueueCreatorViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="620" d:DesignWidth="980">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBooleanConverter x:Key="InverseBool" />
    </UserControl.Resources>
    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top"
                Margin="0,0,0,12"
                Padding="12,10"
                Background="{DynamicResource UiBrush.SurfaceElevated}"
                BorderBrush="{DynamicResource UiBrush.Secondary}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <Border HorizontalAlignment="Left"
                        Padding="8,3"
                        CornerRadius="4"
                        Background="{DynamicResource UiBrush.Secondary}"
                        Margin="0,0,0,8">
                    <TextBlock Text="{loc:Loc QueueCreator_ExperimentalBadge}"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{DynamicResource UiBrush.OnSecondary}" />
                </Border>
                <TextBlock Text="{loc:Loc QueueCreator_ExperimentalNotice}"
                           TextWrapping="Wrap"
                           FontSize="13"
                           LineHeight="20"
                           Foreground="{DynamicResource UiBrush.TextPrimary}" />
            </StackPanel>
        </Border>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="{loc:Loc QueueCreator_QueueNameLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="{DynamicResource UiBrush.TextPrimary}" />
            <TextBox Text="{Binding QueueName, UpdateSourceTrigger=PropertyChanged}"
                     Width="220"
                     Margin="0,0,16,0"
                     VerticalAlignment="Center"
                     Style="{DynamicResource UiTextBox}" />
            <CheckBox Content="{loc:Loc QueueCreator_LoopWholeQueue}"
                      IsChecked="{Binding LoopWholeQueue}"
                      VerticalAlignment="Center"
                      Margin="0,0,16,0"
                      Foreground="{DynamicResource UiBrush.TextPrimary}"
                      Style="{DynamicResource UiCheckBoxModern}" />
            <TextBlock Text="{Binding EstimatedDurationText}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource UiBrush.TextSecondary}"
                       TextWrapping="Wrap"
                       MaxWidth="360" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{loc:Loc QueueCreator_Save}"
                    Command="{Binding SaveQueueCommand}"
                    Margin="0,0,8,0"
                    Padding="12,6"
                    Style="{DynamicResource UiButtonChrome}" />
            <Button Content="{loc:Loc QueueCreator_Load}"
                    Command="{Binding LoadQueueCommand}"
                    Margin="0,0,8,0"
                    Padding="12,6"
                    Style="{DynamicResource UiButtonChrome}" />
            <Button Content="{loc:Loc QueueCreator_Run}"
                    Command="{Binding RunQueueCommand}"
                    IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBool}}"
                    Margin="0,0,8,0"
                    Padding="12,6"
                    Style="{DynamicResource UiPrimaryButton}" />
            <Button Content="{loc:Loc QueueCreator_Stop}"
                    Command="{Binding StopQueueCommand}"
                    Margin="0,0,8,0"
                    Padding="12,6"
                    Style="{DynamicResource UiButtonChrome}"
                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />
            <Button Content="{Binding PauseToggleLabel}"
                    Command="{Binding TogglePauseCommand}"
                    Padding="12,6"
                    Style="{DynamicResource UiButtonChrome}"
                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top"
                           Text="{loc:Loc QueueCreator_AvailableMacros}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"
                           Foreground="{DynamicResource UiBrush.TextPrimary}" />
                <Border Background="{DynamicResource UiBrush.Surface}"
                        BorderBrush="{DynamicResource UiBrush.Border}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="0,4">
                    <ListView x:Name="MacroListView"
                              ItemsSource="{Binding AvailableMacros}"
                              BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              PreviewMouseLeftButtonDown="OnMacroListPreviewMouseLeftButtonDown"
                              PreviewMouseMove="OnMacroListPreviewMouseMove"
                              PreviewMouseLeftButtonUp="OnMacroListPreviewMouseLeftButtonUp">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                           TextWrapping="Wrap"
                                           Padding="8,4"
                                           Foreground="{DynamicResource UiBrush.TextPrimary}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </DockPanel>
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Center"
                          Background="Transparent" />
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="120" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="{loc:Loc QueueCreator_Steps}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Foreground="{DynamicResource UiBrush.TextPrimary}" />
                    <Button DockPanel.Dock="Left"
                            Content="{loc:Loc QueueCreator_AddStep}"
                            Command="{Binding AddStepCommand}"
                            Margin="0,0,6,0"
                            Padding="10,5"
                            Style="{DynamicResource UiPrimaryButton}" />
                    <Button DockPanel.Dock="Left"
                            Content="{loc:Loc QueueCreator_Remove}"
                            Command="{Binding RemoveStepCommand}"
                            CommandParameter="{Binding SelectedStep}"
                            Margin="0,0,6,0"
                            Padding="10,5"
                            Style="{DynamicResource UiButtonChrome}" />
                    <Button DockPanel.Dock="Left"
                            Content="{loc:Loc QueueCreator_Duplicate}"
                            Command="{Binding DuplicateStepCommand}"
                            CommandParameter="{Binding SelectedStep}"
                            Margin="0,0,6,0"
                            Padding="10,5"
                            Style="{DynamicResource UiButtonChrome}" />
                    <Button DockPanel.Dock="Left"
                            Content="{loc:Loc QueueCreator_MoveUp}"
                            Command="{Binding MoveStepUpCommand}"
                            CommandParameter="{Binding SelectedStep}"
                            Margin="0,0,6,0"
                            Padding="10,5"
                            Style="{DynamicResource UiButtonChrome}" />
                    <Button DockPanel.Dock="Left"
                            Content="{loc:Loc QueueCreator_MoveDown}"
                            Command="{Binding MoveStepDownCommand}"
                            CommandParameter="{Binding SelectedStep}"
                            Margin="0,0,6,0"
                            Padding="10,5"
                            Style="{DynamicResource UiButtonChrome}" />
                </DockPanel>
                <Border Grid.Row="1"
                        Background="{DynamicResource UiBrush.Surface}"
                        BorderBrush="{DynamicResource UiBrush.Border}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="0,4"
                        Margin="0,0,0,10"
                        AllowDrop="True"
                        DragOver="OnStepsAreaDragOver"
                        Drop="OnStepsAreaDrop">
                    <ListView x:Name="StepsListView"
                              ItemsSource="{Binding Steps}"
                              SelectedItem="{Binding SelectedStep}"
                              BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              AllowDrop="True"
                              DragOver="OnStepsAreaDragOver"
                              Drop="OnStepsAreaDrop">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="6,4" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:QueueStepRowViewModel}">
                                <Border Padding="4"
                                        CornerRadius="4"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource UiBrush.Border}"
                                        Background="{DynamicResource UiBrush.WindowBackground}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MacroMissing}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#C44" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="88" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0"
                                                      Margin="0,0,8,0"
                                                      Style="{DynamicResource UiComboBox}"
                                                      ItemsSource="{Binding DataContext.AvailableMacros, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedValue="{Binding MacroId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Id"
                                                      DisplayMemberPath="Name" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="{loc:Loc QueueCreator_RepeatShort}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,4,0"
                                                           Foreground="{DynamicResource UiBrush.TextSecondary}" />
                                                <TextBox Text="{Binding RepeatCountText, UpdateSourceTrigger=PropertyChanged}"
                                                         Width="40"
                                                         VerticalAlignment="Center"
                                                         Style="{DynamicResource UiTextBoxCompact}" />
                                            </StackPanel>
                                        </Grid>
                                        <UniformGrid Grid.Row="1" Rows="1" Columns="3" Margin="0,8,0,0">
                                            <StackPanel Margin="0,0,6,0">
                                                <TextBlock Text="{loc:Loc QueueCreator_InitialDelayShort}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource UiBrush.TextSecondary}" />
                                                <TextBox Text="{Binding InitialDelayText, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="{loc:Loc QueueCreator_TimeHint}"
                                                         Style="{DynamicResource UiTextBoxCompact}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,6,0">
                                                <TextBlock Text="{loc:Loc QueueCreator_BetweenRunsShort}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource UiBrush.TextSecondary}" />
                                                <TextBox Text="{Binding DelayBetweenRunsText, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="{loc:Loc QueueCreator_TimeHint}"
                                                         Style="{DynamicResource UiTextBoxCompact}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="{loc:Loc QueueCreator_PostStepShort}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource UiBrush.TextSecondary}" />
                                                <TextBox Text="{Binding PostStepDelayText, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="{loc:Loc QueueCreator_TimeHint}"
                                                         Style="{DynamicResource UiTextBoxCompact}" />
                                            </StackPanel>
                                        </UniformGrid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
                <TextBlock Grid.Row="2"
                           Text="{loc:Loc QueueCreator_TimelineHeader}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource UiBrush.TextPrimary}" />
                <Border Grid.Row="3"
                        Background="{DynamicResource UiBrush.Surface}"
                        BorderBrush="{DynamicResource UiBrush.Border}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8">
                    <ListBox ItemsSource="{Binding TimelinePreviewLines}"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource UiBrush.TextPrimary}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             FontFamily="Consolas"
                             FontSize="12">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextPrimary}" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Padding" Value="2,1" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource UiBrush.SurfaceHover}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource UiBrush.SurfaceSelected}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
