<UserControl x:Class="MacroRecorder.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             xmlns:views="clr-namespace:MacroRecorder.App.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="720"
             Background="{DynamicResource UiBrush.WindowBackground}">
    <Grid Margin="16,8,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
                Margin="0,0,0,6"
                Padding="10,10,10,0"
                Background="{DynamicResource UiBrush.SurfaceElevated}"
                BorderBrush="{DynamicResource UiBrush.Border}"
                BorderThickness="1"
                CornerRadius="12"
                SnapsToDevicePixels="True">
            <TabControl x:Name="SettingsTabControl"
                        SelectedIndex="{Binding SelectedSettingsTabIndex, Mode=OneWay}"
                        SelectionChanged="SettingsTabControl_OnSelectionChanged"
                        Style="{DynamicResource UiTabControl}"
                        ItemContainerStyle="{DynamicResource UiTabItem}">
                <TabItem Header="{loc:Loc Main_Settings_TabGeneral}">
                    <views:GeneralSettingsView />
                </TabItem>
                <TabItem Header="{loc:Loc Main_Settings_TabVisuals}">
                    <views:VisualSettingsView />
                </TabItem>
                <TabItem Header="{loc:Loc Main_Settings_TabMacro}">
                    <views:MacroSettingsView />
                </TabItem>
            </TabControl>
        </Border>
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="{loc:Loc Main_Settings_Save}"
                    MinWidth="96"
                    Padding="12,6"
                    IsDefault="True"
                    Style="{DynamicResource UiPrimaryButton}"
                    Command="{Binding SaveSettingsCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
