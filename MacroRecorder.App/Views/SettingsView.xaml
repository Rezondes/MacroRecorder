<UserControl x:Class="MacroRecorder.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             xmlns:views="clr-namespace:MacroRecorder.App.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="720">
    <TabControl Margin="16,8,16,16" Background="Transparent" BorderThickness="0">
        <TabItem Header="{loc:Loc Main_Settings_TabGeneral}">
            <views:GeneralSettingsView />
        </TabItem>
    </TabControl>
</UserControl>
