<UserControl x:Class="MacroRecorder.App.Views.RecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:swc="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="240" d:DesignWidth="440">
    <UserControl.Resources>
        <swc:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock TextWrapping="Wrap" Margin="0,0,0,16"
                   Text="{loc:Loc Record_Description}" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="{loc:Loc Record_Start}" Padding="16,8" Margin="8"
                    Command="{Binding StartCommand}" />
            <Button Content="{loc:Loc Record_Stop}" Padding="16,8" Margin="8"
                    Command="{Binding StopCommand}" />
        </StackPanel>
        <TextBlock HorizontalAlignment="Center" Margin="0,16,0,0" Foreground="DarkGreen"
                   Text="{loc:Loc Record_StatusRunning}"
                   Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}" />
    </StackPanel>
</UserControl>
