<UserControl x:Class="MacroRecorder.App.Views.UpdateAvailableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             Background="Transparent"
             Focusable="True">
    <Border Style="{DynamicResource UiDialogSurface}"
            Padding="22">
        <StackPanel MinWidth="360">
            <TextBlock x:Name="TitleBlock"
                       Style="{DynamicResource UiDialogTitle}"
                       FontSize="16"
                       Margin="0,0,0,8" />
            <TextBlock x:Name="MessageBlock"
                       Style="{DynamicResource UiDialogDescription}"
                       FontSize="13"
                       Margin="0,0,0,14"
                       TextWrapping="Wrap"
                       LineHeight="20" />
            <StackPanel Style="{DynamicResource UiDialogFooter}"
                        Margin="0,0,0,0">
                <Button Content="{loc:Loc Update_Later}"
                        MinWidth="100"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Style="{DynamicResource UiButtonChrome}"
                        Click="OnLaterClick" />
                <Button Content="{loc:Loc Update_ApplyNow}"
                        MinWidth="140"
                        Padding="12,6"
                        IsDefault="True"
                        Style="{DynamicResource UiPrimaryButton}"
                        Click="OnApplyNowClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
