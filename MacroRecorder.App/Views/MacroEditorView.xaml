<UserControl x:Class="MacroRecorder.App.Views.MacroEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MacroRecorder.App"
             xmlns:controls="clr-namespace:MacroRecorder.App.Controls"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="960"
             Background="{DynamicResource UiBrush.WindowBackground}">
    <UserControl.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}" />
        <KeyBinding Key="Z" Modifiers="Control+Shift" Command="{Binding RedoCommand}" />
    </UserControl.InputBindings>
    <UserControl.Resources>
        <local:InverseBooleanConverter x:Key="InverseBool" />
    </UserControl.Resources>
    <DockPanel Margin="16,8,16,16">
        <Border DockPanel.Dock="Top"
                Margin="0,0,0,12"
                Padding="14,12"
                Background="{DynamicResource UiBrush.Surface}"
                BorderBrush="{DynamicResource UiBrush.Border}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <DockPanel LastChildFill="False" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <controls:PlayMacroGlyphButton Margin="0,0,8,0"
                                                       Command="{Binding PlayTestCommand}" />
                        <Button Command="{Binding ToggleRecordingCommand}"
                                IsEnabled="{Binding EditorHasMacro}"
                                Margin="0,0,8,0"
                                Style="{DynamicResource UiIconButton}"
                                ToolTip="{Binding RecordingButtonCaption}"
                                AutomationProperties.Name="{Binding RecordingButtonCaption}">
                            <Grid Width="20" Height="20">
                                <Ellipse Width="12"
                                         Height="12"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{DynamicResource UiBrush.Error}" />
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <Rectangle Width="10"
                                           Height="10"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RadiusX="1"
                                           RadiusY="1">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Fill" Value="#2196F3" />
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                            </Grid>
                        </Button>
                        <Border Width="1"
                                Height="28"
                                Margin="4,0,12,0"
                                Background="{DynamicResource UiBrush.Border}"
                                VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" IsEnabled="{Binding CanUseCommandsWhileNotRecording}">
                            <Button Margin="0,0,8,0"
                                    Style="{DynamicResource UiIconButtonSuccessGlyph}"
                                    Command="{Binding SaveCommand}"
                                    ToolTip="{loc:Loc Editor_Save}"
                                    AutomationProperties.Name="{loc:Loc Editor_Save}">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE74E;"
                                           FontSize="18"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                            <Border Width="1"
                                    Height="22"
                                    Margin="4,0,12,0"
                                    Background="{DynamicResource UiBrush.Border}"
                                    VerticalAlignment="Center" />
                            <Button Margin="0,0,8,0"
                                    Style="{DynamicResource UiIconButtonPrimaryGlyph}"
                                    Command="{Binding UndoCommand}"
                                    ToolTip="{loc:Loc Editor_Undo}"
                                    AutomationProperties.Name="{loc:Loc Editor_Undo}">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE7A7;"
                                           FontSize="18"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                            <Button Margin="0,0,8,0"
                                    Style="{DynamicResource UiIconButtonPrimaryGlyph}"
                                    Command="{Binding RedoCommand}"
                                    ToolTip="{loc:Loc Editor_Redo}"
                                    AutomationProperties.Name="{loc:Loc Editor_Redo}">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE7A6;"
                                           FontSize="18"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
                <DockPanel LastChildFill="False" Margin="0,0,0,10">
                    <TextBlock DockPanel.Dock="Left"
                               Text="{loc:Loc Editor_SectionRecording}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource UiBrush.TextSecondary}" />
                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal"
                                IsEnabled="{Binding CanUseCommandsWhileNotRecording}">
                        <CheckBox Margin="0,0,16,0"
                                  Style="{DynamicResource UiCheckBoxModern}"
                                  Content="{loc:Loc Editor_RecordMouseMoves}"
                                  IsChecked="{Binding RecordMouseMoves, Mode=TwoWay}"
                                  Foreground="{DynamicResource UiBrush.TextPrimary}" />
                        <CheckBox Style="{DynamicResource UiCheckBoxModern}"
                                  Content="{loc:Loc Editor_UseFocusBoundMousePositions}"
                                  ToolTip="{loc:Loc Editor_UseFocusBoundMousePositions_ToolTip}"
                                  IsChecked="{Binding UseFocusBoundMousePositions, Mode=TwoWay}"
                                  Foreground="{DynamicResource UiBrush.TextPrimary}" />
                    </StackPanel>
                </DockPanel>
                <DockPanel LastChildFill="False" Margin="0,0,0,10">
                    <TextBlock DockPanel.Dock="Left"
                               Text="{loc:Loc Editor_SectionSelection}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource UiBrush.TextSecondary}" />
                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal"
                                IsEnabled="{Binding CanUseCommandsWhileNotRecording}">
                        <Button Content="{loc:Loc Editor_MoveUp}" Style="{DynamicResource UiToolbarChromeButton}" Command="{Binding MoveRowUpCommand}" />
                        <Button Content="{loc:Loc Editor_MoveDown}" Style="{DynamicResource UiToolbarChromeButton}" Command="{Binding MoveRowDownCommand}" />
                        <Button Content="{loc:Loc Editor_Duplicate}" Style="{DynamicResource UiToolbarChromeButton}" Command="{Binding DuplicateSelectedCommand}" />
                        <Button Content="{loc:Loc Editor_EditRow}" Style="{DynamicResource UiToolbarChromeButton}" Command="{Binding EditSelectedCommand}" />
                        <Button Content="{loc:Loc Editor_Delete}" Style="{DynamicResource UiToolbarChromeButton}" Command="{Binding DeleteSelectedCommand}" />
                    </StackPanel>
                </DockPanel>
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="{loc:Loc Editor_SectionInsert}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource UiBrush.TextSecondary}" />
                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal">
                    <ToggleButton x:Name="InsertStepMenuToggle"
                                  Style="{DynamicResource UiToolbarDropDownToggle}"
                                  Content="{loc:Loc Editor_MenuInsertStep}"
                                  IsEnabled="{Binding CanUseCommandsWhileNotRecording}" />
                    <Popup PlacementTarget="{Binding ElementName=InsertStepMenuToggle}"
                           Placement="Bottom"
                           VerticalOffset="4"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           IsOpen="{Binding IsChecked, ElementName=InsertStepMenuToggle, Mode=TwoWay}">
                        <Border MinWidth="260"
                                Background="{DynamicResource UiBrush.SurfaceElevated}"
                                BorderBrush="{DynamicResource UiBrush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="4,6">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16"
                                                  ShadowDepth="2"
                                                  Opacity="0.22"
                                                  Direction="270" />
                            </Border.Effect>
                            <StackPanel>
                                <Button Style="{DynamicResource UiInsertStepMenuItemButton}"
                                        Content="{loc:Loc Editor_MenuWaitBefore}"
                                        Command="{Binding InsertWaitBeforeCommand}"
                                        Click="OnInsertStepMenuItemClick" />
                                <Button Style="{DynamicResource UiInsertStepMenuItemButton}"
                                        Content="{loc:Loc Editor_MenuWaitAfter}"
                                        Command="{Binding InsertWaitAfterCommand}"
                                        Click="OnInsertStepMenuItemClick" />
                                <Border Height="1"
                                        Margin="10,6"
                                        Background="{DynamicResource UiBrush.Border}" />
                                <Button Style="{DynamicResource UiInsertStepMenuItemButton}"
                                        Content="{loc:Loc Editor_MenuMouseBefore}"
                                        Command="{Binding InsertMouseClickBeforeCommand}"
                                        Click="OnInsertStepMenuItemClick" />
                                <Button Style="{DynamicResource UiInsertStepMenuItemButton}"
                                        Content="{loc:Loc Editor_MenuMouseAfter}"
                                        Command="{Binding InsertMouseClickAfterCommand}"
                                        Click="OnInsertStepMenuItemClick" />
                                <Border Height="1"
                                        Margin="10,6"
                                        Background="{DynamicResource UiBrush.Border}" />
                                <Button Style="{DynamicResource UiInsertStepMenuItemButton}"
                                        Content="{loc:Loc Editor_MenuKeyBefore}"
                                        Command="{Binding InsertKeyBeforeCommand}"
                                        Click="OnInsertStepMenuItemClick" />
                                <Button Style="{DynamicResource UiInsertStepMenuItemButton}"
                                        Content="{loc:Loc Editor_MenuKeyAfter}"
                                        Command="{Binding InsertKeyAfterCommand}"
                                        Click="OnInsertStepMenuItemClick" />
                            </StackPanel>
                        </Border>
                    </Popup>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource UiBrush.TextSecondary}"
                               TextWrapping="Wrap"
                               Text="{loc:Loc Editor_HintInsertDrag}" />
                </DockPanel>
            </StackPanel>
        </Border>
        <TextBlock DockPanel.Dock="Bottom"
                   Margin="0,8,0,0"
                   Foreground="{DynamicResource UiBrush.TextSecondary}"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Text="{Binding StatusText}" />
        <Border Background="{DynamicResource UiBrush.Surface}"
                BorderBrush="{DynamicResource UiBrush.Border}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="0"
                ClipToBounds="True">
            <Grid ClipToBounds="True">
                <ListView x:Name="TimelineList"
                          BorderThickness="0"
                          Background="Transparent"
                          VirtualizingPanel.IsVirtualizing="False"
                          AllowDrop="{Binding IsRecording, Converter={StaticResource InverseBool}}"
                          ItemsSource="{Binding Rows}"
                          SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                          MouseDoubleClick="OnTimelineDoubleClick"
                          PreviewMouseLeftButtonDown="OnTimelinePreviewMouseLeftButtonDown"
                          PreviewMouseMove="OnTimelinePreviewMouseMove"
                          PreviewMouseLeftButtonUp="OnTimelinePreviewMouseLeftButtonUp"
                          DragOver="OnTimelineDragOver"
                          Drop="OnTimelineDrop"
                          Loaded="OnLoaded"
                          Unloaded="OnUnloaded"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.Resources>
                        <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource UiGridViewColumnHeader}" />
                    </ListView.Resources>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="4,2" />
                            <Setter Property="MinHeight" Value="40" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="RowBd"
                                                Background="{TemplateBinding Background}"
                                                BorderThickness="0"
                                                Padding="{TemplateBinding Padding}"
                                                SnapsToDevicePixels="False">
                                            <GridViewRowPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                  Content="{TemplateBinding Content}"
                                                                  Columns="{Binding View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="RowBd" Property="Background" Value="{DynamicResource UiBrush.SurfaceHover}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="RowBd" Property="Background" Value="{DynamicResource UiBrush.SurfaceSelected}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="44"
                                            HeaderContainerStyle="{StaticResource UiGridViewIconColumnHeader}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TimelineIconGlyph}"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="17"
                                                   Foreground="{DynamicResource UiBrush.TextSecondary}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Padding="6,8"
                                                   TextAlignment="Center"
                                                   ToolTip="{Binding ActionLabel}"
                                                   AutomationProperties.Name="{Binding ActionLabel}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="{loc:Loc Editor_GridAction}" Width="260">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ActionLabel}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource UiBrush.TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   Padding="10,8"
                                                   VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="{loc:Loc Editor_GridValue}" Width="640">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ValueText}"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource UiBrush.TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   Padding="10,8"
                                                   VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
                <Canvas x:Name="DropIndicatorCanvas"
                        IsHitTestVisible="False"
                        Background="Transparent">
                    <Rectangle x:Name="DropInsertIndicator"
                               Height="3"
                               Fill="{DynamicResource UiBrush.Primary}"
                               RadiusX="1"
                               RadiusY="1"
                               Visibility="Collapsed"
                               IsHitTestVisible="False" />
                </Canvas>
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
