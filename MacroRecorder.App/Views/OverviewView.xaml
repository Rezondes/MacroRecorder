<UserControl x:Class="MacroRecorder.App.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MacroRecorder.App"
             xmlns:controls="clr-namespace:MacroRecorder.App.Controls"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="880">
    <UserControl.Resources>
        <local:MacroListSummaryLineConverter x:Key="MacroSummaryLine" />
    </UserControl.Resources>
    <DockPanel Margin="16">
        <Border Background="{DynamicResource UiBrush.Surface}"
                BorderBrush="{DynamicResource UiBrush.Border}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="0,4">
            <Grid ClipToBounds="True">
            <ListView x:Name="MacroOverviewList"
                      ItemsSource="{Binding Macros}"
                      BorderThickness="0"
                      Background="Transparent"
                      AllowDrop="True"
                      PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown"
                      PreviewMouseLeftButtonUp="OnPreviewMouseLeftButtonUp"
                      PreviewMouseMove="OnPreviewMouseMove"
                      DragOver="OnMacroListDragOver"
                      DragLeave="OnMacroListDragLeave"
                      Drop="OnMacroListDrop"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="12,6" />
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="0"
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="true">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource UiBrush.SurfaceHover}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource UiBrush.SurfaceSelected}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid MinHeight="52">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        Orientation="Vertical"
                                        VerticalAlignment="Center"
                                        Margin="0,0,16,0">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{DynamicResource UiBrush.TextPrimary}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Foreground="{DynamicResource UiBrush.TextSecondary}"
                                           FontSize="12"
                                           Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource MacroSummaryLine}">
                                            <Binding Path="ActionCount" />
                                            <Binding Path="TotalPlaybackDuration" />
                                            <Binding Path="LastModifiedUtc" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right">
                                <controls:PlayMacroGlyphButton Margin="4,0,0,0"
                                                               Command="{Binding DataContext.Overview.PlayCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                               CommandParameter="{Binding}" />
                                <Button Margin="4,0,0,0"
                                        Style="{DynamicResource UiIconButtonSecondaryGlyph}"
                                        ToolTip="{loc:Loc Main_Edit}"
                                        AutomationProperties.Name="{loc:Loc Main_Edit}"
                                        Command="{Binding DataContext.Overview.EditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               Text="&#xE70F;"
                                               FontSize="18"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                </Button>
                                <Button Margin="4,0,0,0"
                                        Style="{DynamicResource UiIconButtonPrimaryGlyph}"
                                        ToolTip="{loc:Loc Main_Export_ToolTip}"
                                        AutomationProperties.Name="{loc:Loc Main_Export_ToolTip}"
                                        Command="{Binding DataContext.Overview.ExportCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               Text="&#xE72D;"
                                               FontSize="18"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                </Button>
                                <Button Margin="4,0,0,0"
                                        Style="{DynamicResource UiIconButtonDangerGlyph}"
                                        ToolTip="{loc:Loc Main_Delete}"
                                        AutomationProperties.Name="{loc:Loc Main_Delete}"
                                        Command="{Binding DataContext.Overview.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               Text="&#xE74D;"
                                               FontSize="18"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <Canvas x:Name="DropIndicatorCanvas"
                    IsHitTestVisible="False"
                    Background="Transparent">
                <Rectangle x:Name="DropInsertIndicator"
                           Height="3"
                           Fill="{DynamicResource UiBrush.Primary}"
                           RadiusX="1"
                           RadiusY="1"
                           Visibility="Collapsed"
                           IsHitTestVisible="False" />
            </Canvas>
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
