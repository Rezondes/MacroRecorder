<UserControl x:Class="MacroRecorder.App.Views.VisualSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
             xmlns:conv="clr-namespace:MacroRecorder.App.Converters"
             xmlns:wpf="clr-namespace:MacroRecorder.Wpf;assembly=MacroRecorder.Wpf"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="420" d:DesignWidth="640">
    <UserControl.Resources>
        <conv:LocResxWithPulseMultiConverter x:Key="LocResxWithPulse" />
        <conv:HexStringToColorConverter x:Key="HexToBrush" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="Transparent">
        <StackPanel Margin="0,12,0,0">
            <TextBlock Text="{loc:Loc Visuals_AppearanceModeHeader}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource UiBrush.TextPrimary}"
                       Margin="0,0,0,8" />
            <Border HorizontalAlignment="Left"
                    Background="{DynamicResource UiBrush.SurfaceElevated}"
                    BorderBrush="{DynamicResource UiBrush.Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="4"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton Grid.Column="0"
                                 GroupName="AppearanceMode"
                                 IsChecked="{Binding IsLightMode, Mode=TwoWay}"
                                 Style="{DynamicResource UiSegmentedAppearanceRadioLeft}"
                                 Content="{loc:Loc Visuals_Light}" />
                    <Border Grid.Column="1"
                            Width="1"
                            Margin="0,6"
                            Background="{DynamicResource UiBrush.Border}" />
                    <RadioButton Grid.Column="2"
                                 GroupName="AppearanceMode"
                                 IsChecked="{Binding IsDarkMode, Mode=TwoWay}"
                                 Style="{DynamicResource UiSegmentedAppearanceRadioRight}"
                                 Content="{loc:Loc Visuals_Dark}" />
                </Grid>
            </Border>

            <TextBlock Text="{loc:Loc Visuals_ColorThemeHeader}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource UiBrush.TextPrimary}"
                       Margin="0,0,0,8" />
            <ItemsControl ItemsSource="{Binding ThemeEntries}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type wpf:ThemeCatalogEntry}">
                        <Border Width="200"
                                Margin="0,0,12,12"
                                Padding="12"
                                Background="{DynamicResource UiBrush.SurfaceElevated}"
                                BorderBrush="{DynamicResource UiBrush.Border}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource UiBrush.TextPrimary}"
                                           Margin="0,0,0,8">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource LocResxWithPulse}">
                                            <Binding Path="DisplayNameKey" />
                                            <Binding Path="Tick"
                                                     Source="{x:Static loc:UiCulturePulse.Instance}" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding SwatchHexes}" Margin="0,0,0,10">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="28"
                                                    Height="20"
                                                    Margin="0,0,4,0"
                                                    CornerRadius="2"
                                                    BorderBrush="{DynamicResource UiBrush.Border}"
                                                    BorderThickness="1"
                                                    Background="{Binding Converter={StaticResource HexToBrush}}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Style="{DynamicResource UiPrimaryButton}"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding DataContext.SelectAppearanceThemeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Id}">
                                    <Button.Content>
                                        <MultiBinding Converter="{StaticResource LocResxWithPulse}"
                                                      ConverterParameter="Visuals_ApplyTheme">
                                            <Binding Path="Tick"
                                                     Source="{x:Static loc:UiCulturePulse.Instance}" />
                                        </MultiBinding>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
