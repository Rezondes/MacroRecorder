<Window x:Class="MacroRecorder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MacroRecorder.App.ViewModels"
        xmlns:views="clr-namespace:MacroRecorder.App.Views"
        xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
        xmlns:brand="clr-namespace:MacroRecorder.Wpf.Branding;assembly=MacroRecorder.Wpf"
        xmlns:swc="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{Binding ShellTitle}"
        Icon="Assets/app-icon.ico"
        Height="640" Width="960"
        MinHeight="400" MinWidth="640"
        Topmost="{Binding IsPinnedTopmost, Mode=OneWay}"
        Background="{DynamicResource UiBrush.WindowBackground}"
        Closing="OnMainWindowClosing"
        PreviewKeyDown="OnPreviewKeyDown">
    <Window.Resources>
        <swc:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <DataTemplate DataType="{x:Type vm:MainViewModel}">
            <views:OverviewView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MacroEditorViewModel}">
            <views:MacroEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RecordViewModel}">
            <views:RecordView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:QueueCreatorViewModel}">
            <views:QueueCreatorView />
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="12,10,12,6" LastChildFill="True">
            <ToggleButton DockPanel.Dock="Right"
                          VerticalAlignment="Center"
                          Margin="8,0,0,0"
                          Style="{DynamicResource UiCaptionIconToggle}"
                          IsChecked="{Binding IsPinnedTopmost, Mode=TwoWay}"
                          ToolTip="{loc:Loc Shell_PinTopmost_ToolTip}"
                          AutomationProperties.Name="{loc:Loc Shell_PinTopmost_A11y}" />
            <Button DockPanel.Dock="Right"
                    VerticalAlignment="Center"
                    Margin="4,0,0,0"
                    Style="{DynamicResource UiIconButton}"
                    ToolTip="{loc:Loc Main_Settings_GearToolTip}"
                    Command="{Binding OpenSettingsCommand}"
                    AutomationProperties.Name="{loc:Loc Main_Settings_GearToolTip}"
                    Visibility="{Binding ShowOverviewHeaderChrome, Converter={StaticResource BoolToVis}}">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE713;"
                           FontSize="18"
                           Foreground="{DynamicResource UiBrush.TextPrimary}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
            </Button>
            <Button DockPanel.Dock="Right"
                    VerticalAlignment="Center"
                    Margin="4,0,0,0"
                    Style="{DynamicResource UiIconButton}"
                    ToolTip="{loc:Loc Main_QueueCreator_ToolTip}"
                    Command="{Binding OpenQueueCreatorCommand}"
                    AutomationProperties.Name="{loc:Loc Main_QueueCreator_ToolTip}"
                    Visibility="{Binding ShowOverviewHeaderChrome, Converter={StaticResource BoolToVis}}">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE8FD;"
                           FontSize="18"
                           Foreground="{DynamicResource UiBrush.TextPrimary}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
            </Button>
            <Button DockPanel.Dock="Right"
                    VerticalAlignment="Center"
                    Margin="4,0,0,0"
                    Style="{DynamicResource UiIconButtonDangerGlyph}"
                    Command="{Binding DeleteCurrentMacroFromEditorCommand}"
                    Visibility="{Binding ShowEditorMacroHeaderActions, Converter={StaticResource BoolToVis}}"
                    ToolTip="{loc:Loc Main_Delete}"
                    AutomationProperties.Name="{loc:Loc Main_Delete}">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE74D;"
                           FontSize="14"
                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Button>
            <Button DockPanel.Dock="Right"
                    VerticalAlignment="Center"
                    Margin="4,0,6,0"
                    Style="{DynamicResource UiIconButton}"
                    Command="{Binding ExportEditorJsonCommand}"
                    Visibility="{Binding ShowEditorMacroHeaderActions, Converter={StaticResource BoolToVis}}"
                    ToolTip="{loc:Loc Main_Export_ToolTip}"
                    AutomationProperties.Name="{loc:Loc Main_Export_ToolTip}">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE72D;"
                           FontSize="14"
                           Foreground="{DynamicResource UiBrush.TextPrimary}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Button>
            <Button DockPanel.Dock="Right"
                    VerticalAlignment="Center"
                    Margin="4,0,0,0"
                    Style="{DynamicResource UiIconButton}"
                    Command="{Binding RenameEditorMacroCommand}"
                    Visibility="{Binding ShowEditorMacroHeaderActions, Converter={StaticResource BoolToVis}}"
                    ToolTip="{loc:Loc Editor_Rename}"
                    AutomationProperties.Name="{loc:Loc Editor_Rename}">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE70F;"
                           FontSize="14"
                           Foreground="{DynamicResource UiBrush.TextPrimary}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Button>
            <Button DockPanel.Dock="Left"
                    Padding="12,6"
                    MinWidth="88"
                    FontSize="13"
                    Command="{Binding GoBackCommand}"
                    Content="{loc:Loc Shell_Back}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource UiButtonChrome}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowBackButton}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <StackPanel DockPanel.Dock="Left"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Margin="8,0,0,0"
                        Visibility="{Binding ShowOverviewHeaderChrome, Converter={StaticResource BoolToVis}}">
                <Button Padding="14,8"
                        FontSize="13"
                        Style="{DynamicResource UiPrimaryButton}"
                        Command="{Binding Overview.NewRecordingCommand}"
                        Content="{loc:Loc Main_NewRecording}" />
                <Button VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        Style="{DynamicResource UiIconButton}"
                        Command="{Binding Overview.ImportMacroCommand}"
                        ToolTip="{loc:Loc Main_Import_ToolTip}"
                        AutomationProperties.Name="{loc:Loc Main_Import_ToolTip}">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE8E5;"
                               FontSize="18"
                               Foreground="{DynamicResource UiBrush.TextPrimary}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Button>
            </StackPanel>
            <Grid Background="Transparent" />
        </DockPanel>
        <ContentControl Grid.Row="1"
                        Margin="0,0,0,8"
                        Content="{Binding CurrentPage}" />
        <Grid Grid.Row="0"
              Grid.RowSpan="2"
              Panel.ZIndex="110"
              Background="{DynamicResource UiBrush.PlaybackOverlay}"
              Visibility="{Binding IsPlaybackOverlayVisible, Converter={StaticResource BoolToVis}}"
              IsHitTestVisible="True">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="24"
                        MaxWidth="520">
                <TextBlock Text="{Binding PlaybackOverlayTitle}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource UiBrush.PlaybackOverlayText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />
                <TextBlock Text="{Binding PlaybackOverlayBody}"
                           FontSize="15"
                           Foreground="{DynamicResource UiBrush.PlaybackOverlayText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"
                           Opacity="0.95" />
                <TextBlock Text="{Binding PlaybackOverlayCountdown}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource UiBrush.PlaybackOverlayText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Margin="0,20,0,0"
                        MinWidth="160"
                        Padding="14,8"
                        HorizontalAlignment="Center"
                        Style="{DynamicResource UiButtonChrome}"
                        Command="{Binding CancelPlaybackFromOverlayCommand}"
                        Visibility="{Binding ShowPlaybackStartDelayCancel, Converter={StaticResource BoolToVis}}"
                        Content="{loc:Loc Playback_Overlay_CancelPlayback}"
                        AutomationProperties.Name="{loc:Loc Playback_Overlay_CancelPlayback}" />
            </StackPanel>
        </Grid>
        <Grid Grid.Row="0"
              Grid.RowSpan="2"
              Panel.ZIndex="114"
              Background="{DynamicResource UiBrush.OverlayScrim}"
              Visibility="{Binding IsContentModalOpen, Converter={StaticResource BoolToVis}}">
            <Border MaxWidth="720"
                    MaxHeight="640"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    MouseDown="OnContentModalInnerMouseDown">
                <ContentControl Content="{Binding ContentModalContent}" />
            </Border>
        </Grid>
        <Grid Grid.Row="0"
              Grid.RowSpan="2"
              Panel.ZIndex="116"
              Background="{DynamicResource UiBrush.OverlayScrim}"
              Visibility="{Binding IsConfirmModalOpen, Converter={StaticResource BoolToVis}}">
            <Border MaxWidth="440"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource UiBrush.Surface}"
                    CornerRadius="8"
                    Padding="20"
                    MouseDown="OnConfirmModalInnerMouseDown">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               FontSize="15"
                               Foreground="{DynamicResource UiBrush.TextPrimary}"
                               Margin="0,0,0,10"
                               Text="{Binding ConfirmModalTitle}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConfirmModalTitle}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding ConfirmModalMessage}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource UiBrush.TextPrimary}"
                               FontSize="13"
                               Margin="0,0,0,16" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button MinWidth="88"
                                Margin="0,0,8,0"
                                Padding="12,6"
                                Style="{DynamicResource UiButtonChrome}"
                                Content="{loc:Loc Common_No}"
                                Command="{Binding ConfirmModalNoCommand}" />
                        <Button MinWidth="88"
                                Padding="12,6"
                                IsDefault="True"
                                Style="{DynamicResource UiPrimaryButton}"
                                Content="{loc:Loc Common_Yes}"
                                Command="{Binding ConfirmModalYesCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        <Grid Grid.Row="0"
              Grid.RowSpan="2"
              Panel.ZIndex="118"
              Background="{DynamicResource UiBrush.OverlayScrim}"
              Visibility="{Binding IsUnsavedChangesModalOpen, Converter={StaticResource BoolToVis}}">
            <Border VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource UiBrush.Surface}"
                    Padding="22"
                    MouseDown="OnUnsavedModalInnerMouseDown">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="MaxWidth" Value="440" />
                        <Setter Property="BorderBrush" Value="{DynamicResource UiBrush.Border}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="CornerRadius" Value="8" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding UnsavedChangesModalIsAppearance}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource UiBrush.Primary}" />
                                <Setter Property="CornerRadius" Value="12" />
                                <Setter Property="MaxWidth" Value="480" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               FontSize="16"
                               Foreground="{DynamicResource UiBrush.TextPrimary}"
                               Margin="0,0,0,8"
                               Text="{Binding UnsavedChangesModalTitle}" />
                    <TextBlock Text="{Binding UnsavedChangesModalMessage}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource UiBrush.TextSecondary}"
                               FontSize="13"
                               LineHeight="20"
                               Margin="0,0,0,20" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button MinWidth="100"
                                Margin="0,0,8,0"
                                Padding="12,7"
                                IsDefault="True"
                                Style="{DynamicResource UiPrimaryButton}"
                                Content="{Binding UnsavedChangesModalSaveLabel}"
                                Command="{Binding UnsavedChangesModalSaveCommand}" />
                        <Button MinWidth="100"
                                Margin="0,0,8,0"
                                Padding="12,7"
                                Style="{DynamicResource UiButtonChrome}"
                                Content="{Binding UnsavedChangesModalDiscardLabel}"
                                Command="{Binding UnsavedChangesModalDiscardCommand}" />
                        <Button MinWidth="100"
                                Margin="0,0,0,0"
                                Padding="12,7"
                                IsCancel="True"
                                Style="{DynamicResource UiButtonChrome}"
                                Content="{loc:Loc Common_Cancel}"
                                Command="{Binding UnsavedChangesModalCancelCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        <Grid Grid.Row="0"
              Grid.RowSpan="2"
              Panel.ZIndex="120"
              Background="{DynamicResource UiBrush.OverlayScrim}"
              Visibility="{Binding IsInfoModalOpen, Converter={StaticResource BoolToVis}}"
              MouseDown="OnInfoOverlayBackgroundMouseDown">
            <Border MaxWidth="440"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource UiBrush.Surface}"
                    CornerRadius="8"
                    Padding="20"
                    MouseDown="OnInfoModalInnerMouseDown">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               FontSize="15"
                               Foreground="{DynamicResource UiBrush.TextPrimary}"
                               Margin="0,0,0,10"
                               Text="{Binding InfoModalTitle}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InfoModalTitle}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding InfoModalMessage}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource UiBrush.TextPrimary}"
                               FontSize="13"
                               Margin="0,0,0,16" />
                    <Button MinWidth="88"
                            HorizontalAlignment="Right"
                            Padding="12,6"
                            IsDefault="True"
                            Style="{DynamicResource UiPrimaryButton}"
                            Content="{loc:Loc Common_Ok}"
                            Command="{Binding CloseInfoModalCommand}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
