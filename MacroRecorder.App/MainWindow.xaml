<Window x:Class="MacroRecorder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MacroRecorder.App.ViewModels"
        xmlns:views="clr-namespace:MacroRecorder.App.Views"
        xmlns:loc="clr-namespace:MacroRecorder.App.Localization"
        xmlns:swc="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{Binding ShellTitle}"
        Height="640" Width="960"
        MinHeight="400" MinWidth="640"
        Background="#F5F5F5"
        Closing="OnMainWindowClosing"
        PreviewKeyDown="OnPreviewKeyDown">
    <Window.Resources>
        <swc:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <DataTemplate DataType="{x:Type vm:MainViewModel}">
            <views:OverviewView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MacroEditorViewModel}">
            <views:MacroEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RecordViewModel}">
            <views:RecordView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="12,10,12,6" LastChildFill="True">
            <Button DockPanel.Dock="Left"
                    Padding="12,6"
                    MinWidth="88"
                    FontSize="13"
                    Command="{Binding GoBackCommand}"
                    Content="{loc:Loc Shell_Back}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowBackButton}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </DockPanel>
        <ContentControl Grid.Row="1"
                        Margin="0,0,0,8"
                        Content="{Binding CurrentPage}" />
        <Grid Grid.Row="0"
              Grid.RowSpan="2"
              Panel.ZIndex="101"
              Background="#99000000"
              Visibility="{Binding IsInfoModalOpen, Converter={StaticResource BoolToVis}}"
              MouseDown="OnInfoOverlayBackgroundMouseDown">
            <Border MaxWidth="440"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Background="White"
                    CornerRadius="8"
                    Padding="20"
                    MouseDown="OnInfoModalInnerMouseDown">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               FontSize="15"
                               Margin="0,0,0,10"
                               Text="{Binding InfoModalTitle}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InfoModalTitle}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding InfoModalMessage}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />
                    <Button MinWidth="88"
                            HorizontalAlignment="Right"
                            Padding="12,6"
                            IsDefault="True"
                            Content="{loc:Loc Common_Ok}"
                            Command="{Binding CloseInfoModalCommand}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
