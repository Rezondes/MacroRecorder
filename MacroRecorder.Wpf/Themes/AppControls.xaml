<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:swc="clr-namespace:System.Windows.Controls;assembly=PresentationFramework">
    <swc:BooleanToVisibilityConverter x:Key="BoolToVis" />

    <!-- Shared flat template: Background comes from the Button (Style triggers update it). -->
    <ControlTemplate x:Key="UiFlatButtonTemplate" TargetType="Button">
        <Border x:Name="Bd"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="6"
                Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="UiButtonChrome" TargetType="Button">
        <Setter Property="Template" Value="{StaticResource UiFlatButtonTemplate}" />
        <Setter Property="Background" Value="{DynamicResource UiBrush.Surface}" />
        <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource UiBrush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource UiBrush.SurfaceHover}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource UiBrush.SurfaceElevated}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="UiPrimaryButton" TargetType="Button">
        <Setter Property="Template" Value="{StaticResource UiFlatButtonTemplate}" />
        <Setter Property="Background" Value="{DynamicResource UiBrush.Primary}" />
        <Setter Property="Foreground" Value="{DynamicResource UiBrush.OnPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource UiBrush.PrimaryDark}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource UiBrush.PrimaryHover}" />
                <Setter Property="BorderBrush" Value="{DynamicResource UiBrush.PrimaryHover}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource UiBrush.PrimaryDark}" />
                <Setter Property="BorderBrush" Value="{DynamicResource UiBrush.PrimaryDark}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="UiIconButton" TargetType="Button" BasedOn="{StaticResource UiButtonChrome}">
        <Setter Property="Padding" Value="10" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="40" />
    </Style>

    <ControlTemplate x:Key="UiFlatToggleButtonTemplate" TargetType="ToggleButton">
        <Border x:Name="Bd"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="6"
                Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
            </Trigger>
            <!-- Later triggers win for the same property. -->
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource UiBrush.SurfaceSelected}" />
                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource UiBrush.Primary}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource UiBrush.SurfaceHover}" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsChecked" Value="True" />
                    <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource UiBrush.SurfaceSelected}" />
            </MultiTrigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource UiBrush.SurfaceElevated}" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsChecked" Value="True" />
                    <Condition Property="IsPressed" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource UiBrush.PrimaryDark}" />
            </MultiTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="UiCaptionIconToggle" TargetType="ToggleButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <Grid x:Name="PinRotateHost"
                              RenderTransformOrigin="0.5,0.5">
                            <!-- Pin rotation when toggle is off (not pinned). -->
                            <Grid.RenderTransform>
                                <RotateTransform Angle="-45" />
                            </Grid.RenderTransform>
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE718;"
                                       FontSize="14"
                                       Foreground="{DynamicResource UiBrush.TextPrimary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <!-- Pin rotation when toggle is on (pinned). -->
                            <Setter TargetName="PinRotateHost" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="-90" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource UiBrush.SurfaceSelected}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource UiBrush.Primary}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource UiBrush.SurfaceHover}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource UiBrush.SurfaceSelected}" />
                        </MultiTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource UiBrush.SurfaceElevated}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource UiBrush.PrimaryDark}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Background" Value="{DynamicResource UiBrush.Surface}" />
        <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource UiBrush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="UiCaptionIconButton" TargetType="Button">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource UiBrush.SurfaceHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource UiBrush.SurfaceElevated}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Background" Value="{DynamicResource UiBrush.Surface}" />
        <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource UiBrush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="UiToolbarChromeButton" TargetType="Button" BasedOn="{StaticResource UiButtonChrome}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="MinHeight" Value="32" />
    </Style>

    <Style x:Key="UiToolbarPrimaryButton" TargetType="Button" BasedOn="{StaticResource UiPrimaryButton}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="UiGridViewColumnHeader" TargetType="GridViewColumnHeader">
        <Setter Property="Background" Value="{DynamicResource UiBrush.SurfaceElevated}" />
        <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextSecondary}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="BorderBrush" Value="{DynamicResource UiBrush.Border}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewColumnHeader">
                    <Border x:Name="HeaderChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderChrome" Property="Background" Value="{DynamicResource UiBrush.SurfaceHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HeaderChrome" Property="Background" Value="{DynamicResource UiBrush.SurfaceSelected}" />
                            <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="HeaderChrome" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- GridView first column: icon slot, no header text (matches action column chrome). -->
    <Style x:Key="UiGridViewIconColumnHeader" TargetType="GridViewColumnHeader" BasedOn="{StaticResource UiGridViewColumnHeader}">
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewColumnHeader">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="8,10"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Non-editable ComboBox (e.g. language picker): rounded, themed popup -->
    <ControlTemplate x:Key="UiComboBoxTemplate" TargetType="ComboBox">
        <Grid SnapsToDevicePixels="True">
            <Border x:Name="OuterBd"
                    CornerRadius="8"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                <DockPanel Margin="{TemplateBinding Padding}" LastChildFill="True" IsHitTestVisible="False">
                    <Path x:Name="Chevron"
                          DockPanel.Dock="Right"
                          Data="M 0 1 L 5 6 L 10 1"
                          Stroke="{DynamicResource UiBrush.TextSecondary}"
                          StrokeThickness="1.6"
                          StrokeLineJoin="Round"
                          Width="12"
                          Height="12"
                          Stretch="None"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"
                          Margin="0,0,8,0"
                          SnapsToDevicePixels="True" />
                    <ContentPresenter Margin="10,0,4,0"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                </DockPanel>
            </Border>
            <ToggleButton x:Name="PART_ToggleButton"
                          Focusable="False"
                          Background="Transparent"
                          BorderThickness="0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>
            <Popup x:Name="PART_Popup"
                   AllowsTransparency="True"
                   Focusable="False"
                   Placement="Bottom"
                   IsOpen="{TemplateBinding IsDropDownOpen}"
                   PlacementTarget="{Binding ElementName=OuterBd}"
                   PopupAnimation="Fade">
                <Border MinWidth="{Binding ActualWidth, ElementName=OuterBd}"
                        MaxHeight="280"
                        Margin="0,4,0,0"
                        CornerRadius="8"
                        Background="{DynamicResource UiBrush.SurfaceElevated}"
                        BorderBrush="{DynamicResource UiBrush.Border}"
                        BorderThickness="1"
                        Padding="0,4">
                    <ScrollViewer SnapsToDevicePixels="True">
                        <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" KeyboardNavigation.DirectionalNavigation="Contained" />
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="OuterBd" Property="BorderBrush" Value="{DynamicResource UiBrush.Primary}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="OuterBd" Property="BorderBrush" Value="{DynamicResource UiBrush.Primary}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="OuterBd" Property="Opacity" Value="0.55" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="UiComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource UiBrush.SurfaceElevated}" />
        <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource UiBrush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="2,2" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template" Value="{StaticResource UiComboBoxTemplate}" />
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Padding" Value="14,10" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextPrimary}" />
                    <Setter Property="FontSize" Value="13" />
                    <Style.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="{DynamicResource UiBrush.SurfaceHover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource UiBrush.SurfaceSelected}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Settings page + dialog typography and chrome (MacroRecorder.App and other hosts) -->
    <Style x:Key="UiSettingsFormScrollViewer" TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="UiSettingsFormStackPanel" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,12,0,0" />
    </Style>

    <Style x:Key="UiSettingsSectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextPrimary}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="UiDialogTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextPrimary}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="UiDialogDescription" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextSecondary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="UiFormFieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextSecondary}" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style x:Key="UiDialogSurface" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource UiBrush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource UiBrush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="UiDialogFooter" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="Margin" Value="0,20,0,0" />
    </Style>

    <Style x:Key="UiSettingsComboBox" TargetType="ComboBox" BasedOn="{StaticResource UiComboBox}">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="UiTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0,4,0,0" />
    </Style>

    <Style x:Key="UiTabItem" TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextPrimary}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="14,12,24,12" />
        <Setter Property="Margin" Value="0,0,10,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Chrome"
                            Background="{DynamicResource UiBrush.Surface}"
                            BorderBrush="{DynamicResource UiBrush.Border}"
                            BorderThickness="1"
                            CornerRadius="10,10,0,0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <StackPanel>
                            <ContentPresenter x:Name="PART_Header"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              RecognizesAccessKey="True" />
                            <Border x:Name="Underline"
                                    Height="4"
                                    Margin="0,10,0,0"
                                    CornerRadius="2"
                                    HorizontalAlignment="Stretch"
                                    Background="Transparent" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource UiBrush.SurfaceElevated}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource UiBrush.Primary}" />
                            <Setter TargetName="Chrome" Property="BorderThickness" Value="2" />
                            <Setter TargetName="Underline" Property="Background" Value="{DynamicResource UiBrush.Primary}" />
                            <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextPrimary}" />
                            <Setter Property="FontSize" Value="16" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource UiBrush.SurfaceHover}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource UiBrush.Primary}" />
                            <Setter TargetName="Chrome" Property="BorderThickness" Value="1" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Vertical scrollbar (ListView / ScrollViewer); themed track + thumb -->
    <Style x:Key="UiScrollBar" TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="16" />
        <Setter Property="MinWidth" Value="16" />
        <Setter Property="Stylus.IsFlicksEnabled" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Border x:Name="TrackHost"
                            Width="16"
                            Margin="2,6,3,6"
                            CornerRadius="6"
                            Background="{DynamicResource UiBrush.SurfaceElevated}"
                            BorderBrush="{DynamicResource UiBrush.Border}"
                            BorderThickness="1"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <RepeatButton Grid.Row="0"
                                          Height="10"
                                          Opacity="0"
                                          Focusable="False"
                                          Command="{x:Static ScrollBar.PageUpCommand}" />
                            <Track x:Name="PART_Track"
                                   Grid.Row="1"
                                   Focusable="False"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Height="0"
                                                  Command="{x:Static ScrollBar.LineUpCommand}"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Height="0"
                                                  Command="{x:Static ScrollBar.LineDownCommand}"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBd"
                                                        Margin="2,2"
                                                        CornerRadius="4"
                                                        Background="{DynamicResource UiBrush.Border}"
                                                        SnapsToDevicePixels="True" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBd" Property="Background" Value="{DynamicResource UiBrush.Primary}" />
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBd" Property="Background" Value="{DynamicResource UiBrush.PrimaryDark}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                            <RepeatButton Grid.Row="2"
                                          Height="10"
                                          Opacity="0"
                                          Focusable="False"
                                          Command="{x:Static ScrollBar.PageDownCommand}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="UiSegmentedAppearanceRadioLeft" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource UiBrush.TextPrimary}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="MinWidth" Value="112" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Track"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="6,0,0,6"
                            Padding="16,8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource UiBrush.Primary}" />
                            <Setter Property="Foreground" Value="{DynamicResource UiBrush.OnPrimary}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource UiBrush.SurfaceHover}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

