<!--
  Vendored from WiX 6.0.2 WixUI_InstallDir; UI Ids renamed to avoid clashes with the stock extension.
  Inserts MacroRecorderOptionsDlg (Start + Desktop-Shortcut) between InstallDirDlg and VerifyReadyDlg.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
    <?foreach WIXUIARCH in X86;X64;A64 ?>
    <Fragment>
        <UI Id="MacroRecorder_WixUI_InstallDir_$(WIXUIARCH)">
            <Publish Dialog="BrowseDlg" Control="OK" Event="CheckTargetPath" Value="[WIXUI_INSTALLDIR]" Order="1" />

            <Publish Dialog="InstallDirDlg" Control="Next" Event="CheckTargetPath" Value="[WIXUI_INSTALLDIR]" Order="1" />
            <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="MacroRecorderOptionsDlg" Order="4" />
        </UI>

        <UIRef Id="MacroRecorder_WixUI_InstallDir" />
    </Fragment>
    <?endforeach?>

    <?foreach WIXUIARCH in X86;X64;A64 ?>
    <Fragment>
        <UI Id="MacroRecorder_WixUI_InstallDir_ExtendedPathValidation_$(WIXUIARCH)">
            <Publish Dialog="BrowseDlg" Control="OK" Event="DoAction" Value="WixUIValidatePath_$(WIXUIARCH)" Order="1" />
            <Publish Dialog="BrowseDlg" Control="OK" Event="SpawnDialog" Value="InvalidDirDlg" Order="2" Condition="WIXUI_INSTALLDIR_VALID&lt;&gt;&quot;1&quot;" />

            <Publish Dialog="InstallDirDlg" Control="Next" Event="DoAction" Value="WixUIValidatePath_$(WIXUIARCH)" Order="1" />
            <Publish Dialog="InstallDirDlg" Control="Next" Event="SpawnDialog" Value="InvalidDirDlg" Order="2" Condition="WIXUI_INSTALLDIR_VALID&lt;&gt;&quot;1&quot;" />
            <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="MacroRecorderOptionsDlg" Order="4" Condition="WIXUI_INSTALLDIR_VALID=&quot;1&quot;" />
        </UI>

        <UIRef Id="MacroRecorder_WixUI_InstallDir" />
    </Fragment>
    <?endforeach?>

    <Fragment>
        <UI Id="file MacroRecorder_WixUI_InstallDir">
            <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
            <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
            <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="9" Bold="yes" />

            <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />

            <DialogRef Id="BrowseDlg" />
            <DialogRef Id="DiskCostDlg" />
            <DialogRef Id="ErrorDlg" />
            <DialogRef Id="FatalError" />
            <DialogRef Id="FilesInUse" />
            <DialogRef Id="MsiRMFilesInUse" />
            <DialogRef Id="PrepareDlg" />
            <DialogRef Id="ProgressDlg" />
            <DialogRef Id="ResumeDlg" />
            <DialogRef Id="UserExit" />
            <DialogRef Id="MacroRecorderOptionsDlg" />

            <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchMacroRecorderAfterInstall" Order="5" Condition="LAUNCH_AFTER_INSTALL=1" />
            <Publish Dialog="ExitDialog" Control="Finish" Event="EndDialog" Value="Return" Order="999" />

            <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="LicenseAgreementDlg" Condition="NOT Installed" />
            <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Condition="Installed AND PATCH" />

            <Publish Dialog="LicenseAgreementDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" />
            <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg" Condition="LicenseAccepted = &quot;1&quot;" />

            <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog" Value="LicenseAgreementDlg" />
            <Publish Dialog="InstallDirDlg" Control="Next" Event="SetTargetPath" Value="[WIXUI_INSTALLDIR]" Order="3" />
            <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Property="_BrowseProperty" Value="[WIXUI_INSTALLDIR]" Order="1" />
            <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Event="SpawnDialog" Value="BrowseDlg" Order="2" />

            <Publish Dialog="BrowseDlg" Control="OK" Event="SetTargetPath" Value="[_BrowseProperty]" Order="3" />
            <Publish Dialog="BrowseDlg" Control="OK" Event="EndDialog" Value="Return" Order="4" />

            <Publish Dialog="MacroRecorderOptionsDlg" Control="Back" Event="NewDialog" Value="InstallDirDlg" />
            <Publish Dialog="MacroRecorderOptionsDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" />

            <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="MacroRecorderOptionsDlg" Order="1" Condition="NOT Installed" />
            <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg" Order="2" Condition="Installed AND NOT PATCH" />
            <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="2" Condition="Installed AND PATCH" />

            <Publish Dialog="MaintenanceWelcomeDlg" Control="Next" Event="NewDialog" Value="MaintenanceTypeDlg" />

            <Publish Dialog="MaintenanceTypeDlg" Control="RepairButton" Event="NewDialog" Value="VerifyReadyDlg" />
            <Publish Dialog="MaintenanceTypeDlg" Control="RemoveButton" Event="NewDialog" Value="VerifyReadyDlg" />
            <Publish Dialog="MaintenanceTypeDlg" Control="Back" Event="NewDialog" Value="MaintenanceWelcomeDlg" />

            <Property Id="ARPNOMODIFY" Value="1" />
        </UI>

        <UIRef Id="WixUI_Common" />
    </Fragment>

    <Fragment>
        <UI Id="MacroRecorderOptionsUiFragment">
            <Dialog Id="MacroRecorderOptionsDlg" Width="370" Height="270" Title="!(loc.Installer_OptionsDlgTitle)">
            <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)" />
            <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
            <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
                <Publish Event="SpawnDialog" Value="CancelDlg" />
            </Control>

            <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
            <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="373" Height="0" />
            <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="373" Height="0" />

            <Control Id="Title" Type="Text" X="15" Y="6" Width="320" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}!(loc.Installer_OptionsDlgHeading)" />
            <Control Id="Description" Type="Text" X="25" Y="50" Width="320" Height="30" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Normal}!(loc.Installer_OptionsDlgDescription)" />

            <Control
              Id="LaunchAfterInstallCheck"
              Type="CheckBox"
              X="25"
              Y="100"
              Width="320"
              Height="18"
              Property="LAUNCH_AFTER_INSTALL"
              CheckBoxValue="1"
              Text="{\WixUI_Font_Normal}!(loc.Installer_OptionsLaunchCheckbox)" />
            <Control
              Id="DesktopShortcutCheck"
              Type="CheckBox"
              X="25"
              Y="125"
              Width="320"
              Height="18"
              Property="DESKTOP_SHORTCUT"
              CheckBoxValue="1"
              Text="{\WixUI_Font_Normal}!(loc.Installer_OptionsDesktopCheckbox)" />
            </Dialog>
        </UI>
    </Fragment>

    <Fragment>
        <CustomAction
          Id="LaunchMacroRecorderAfterInstall"
          Directory="System64Folder"
          ExeCommand="cmd.exe /c start &quot;&quot; &quot;[INSTALLFOLDER]Macro Recorder by Rezondes.exe&quot;"
          Execute="immediate"
          Impersonate="yes"
          Return="ignore" />
    </Fragment>

    <Fragment>
        <CustomAction
          Id="CreateCommonDesktopShortcut"
          Directory="System64Folder"
          Execute="immediate"
          Impersonate="no"
          Return="ignore"
          ExeCommand="powershell.exe -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -Command &quot;if ('[DESKTOP_SHORTCUT]' -ne '1') { exit 0 }; $e='[INSTALLFOLDER]Macro Recorder by Rezondes.exe'; if (-not (Test-Path -LiteralPath $e)) { exit 0 }; $d=[Environment]::GetFolderPath('CommonDesktopDirectory'); $w=New-Object -ComObject WScript.Shell; $s=$w.CreateShortcut((Join-Path $d 'Macro Recorder by Rezondes.lnk')); $s.TargetPath=$e; $s.WorkingDirectory=[System.IO.Path]::GetDirectoryName($e); $s.Save()&quot;" />
        <InstallExecuteSequence>
            <Custom Action="CreateCommonDesktopShortcut" After="InstallFiles" Condition="DESKTOP_SHORTCUT=1 AND NOT REMOVE" />
        </InstallExecuteSequence>
    </Fragment>

    <Fragment>
        <CustomAction
          Id="RemoveCommonDesktopShortcut"
          Directory="System64Folder"
          Execute="immediate"
          Impersonate="no"
          Return="ignore"
          ExeCommand="powershell.exe -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -Command &quot;$p=Join-Path ([Environment]::GetFolderPath('CommonDesktopDirectory')) 'Macro Recorder by Rezondes.lnk'; if (Test-Path -LiteralPath $p) { Remove-Item -LiteralPath $p -Force }&quot;" />
        <InstallExecuteSequence>
            <Custom Action="RemoveCommonDesktopShortcut" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
        </InstallExecuteSequence>
    </Fragment>
</Wix>
